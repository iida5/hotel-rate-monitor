# このファイルを .env にコピーして値を埋めてください
#   copy .env.example .env
# シェルで設定した環境変数の方が .env より優先されます

# ---- サーバー設定 ----
# PORT=3000
# HOST=127.0.0.1

# ---- 競合レート監視 ----
# データソース: browser=ブラウザ収集(既定/APIキー不要) / rakuten=API / sim=デモ
RATESHOP_SOURCE=browser
# 下記5項目 (RATESHOP_HOTELS / OWN / DATES / ADULTS / CONCURRENCY) は
# 初回起動時の既定値です。起動後は画面右上の「設定」から変更でき、
# 変更内容は data/rateshop-config.json に保存されてこちらより優先されます。

# 監視する楽天トラベルの施設番号 (カンマ区切り)。施設ページURLの数字
RATESHOP_HOTELS=
# 上記のうち自社の施設番号 (任意)
# RATESHOP_OWN=
# 監視するチェックイン日 (今日から何日後か)
# RATESHOP_DATES=1,3,7,14,30
# 空室検索する宿泊人数。カンマ区切りで最大3条件を並行監視 (例 1,2)
# RATESHOP_ADULTS=1,2
# アラート送信先の Slack 互換 Webhook URL (任意)
# RATESHOP_WEBHOOK=
# Webhookで送る種別 (既定: 価格・売止・再開のみ。在庫増減は送らない)
# RATESHOP_WEBHOOK_TYPES=price_up,price_down,soldout,restock
# Webhookで送る価格変動の最小% (例 5 で±5%以上のみ)
# RATESHOP_WEBHOOK_PCT=0

# ---- ブラウザ収集モード (RATESHOP_SOURCE=browser) ----
# 同時に開くブラウザページ数 (1〜10)。多いほど速いがブロックされやすい
RATESHOP_CONCURRENCY=3
# 残室数プローブの最大段数 (1〜10)。予約部屋数を増やしながらページを読み、
# 「一度に何室予約できるか」で残室を推定する。1で無効 (残りX室バッジの実値のみ)
# RATESHOP_STOCK_PROBE=5
# 1 にするとブラウザを画面表示 (デバッグ用。既定はヘッドレス)
# RATESHOP_HEADFUL=1

# ---- 楽天トラベルAPIモード (RATESHOP_SOURCE=rakuten のときのみ) ----
# アプリIDとアクセスキーは https://webservice.rakuten.co.jp/app/list で確認
# RAKUTEN_APP_ID=
# RAKUTEN_ACCESS_KEY=
# 403エラーが出る場合のみ: アプリ登録した「許可されたWebサイト」のドメイン
# RAKUTEN_ORIGIN=https://github.com
# 残室数プローブの最大段数 (1〜10)。1でプローブ無効 (売止/再販売のみ)
# RATESHOP_STOCK_PROBE=5
